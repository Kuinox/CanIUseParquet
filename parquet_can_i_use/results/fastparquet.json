{
  "tool": "fastparquet",
  "version": "2025.12.0",
  "compression": {
    "NONE": true,
    "SNAPPY": true,
    "GZIP": true,
    "BROTLI": true,
    "LZO": false,
    "LZ4": true,
    "LZ4_RAW": true,
    "ZSTD": true
  },
  "encoding": {
    "PLAIN": true,
    "PLAIN_DICTIONARY": true,
    "RLE_DICTIONARY": true,
    "RLE": true,
    "BIT_PACKED": true,
    "DELTA_BINARY_PACKED": false,
    "DELTA_LENGTH_BYTE_ARRAY": false,
    "DELTA_BYTE_ARRAY": false,
    "BYTE_STREAM_SPLIT": false
  },
  "logical_types": {
    "STRING": true,
    "DATE": false,
    "TIME_MILLIS": false,
    "TIME_MICROS": false,
    "TIME_NANOS": false,
    "TIMESTAMP_MILLIS": true,
    "TIMESTAMP_MICROS": true,
    "TIMESTAMP_NANOS": true,
    "INT96": true,
    "DECIMAL": true,
    "UUID": true,
    "JSON": true,
    "FLOAT16": true,
    "ENUM": false,
    "BSON": true,
    "INTERVAL": true
