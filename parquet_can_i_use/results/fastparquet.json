  "nested_types": {
    "LIST": true,
    "MAP": true,
    "STRUCT": true,
    "NESTED_LIST": true,
    "NESTED_MAP": true,
    "DEEP_NESTING": true
  },
  "advanced_features": {
    "STATISTICS": true,
    "PREDICATE_PUSHDOWN": true,
