{
  "_comment": "Reference data from the Apache Parquet official implementation status page: https://parquet.apache.org/docs/file-format/implementationstatus/ (source: https://github.com/apache/parquet-site/tree/production/data/implementations). Used to highlight discrepancies between our automated test results and the Apache project's own claims. Only includes tools that overlap between our matrix and the Apache page.",
  "_tool_mapping": {
    "parquet-java": "parquet-java",
    "parquet-rs": "arrow-rs",
    "duckdb": "duckdb",
    "polars": "polars"
  },
  "parquet-java": {
    "_apache_engine_id": "parquet-java",
    "compression": {
      "NONE":    { "write": true,  "read": true  },
      "BROTLI":  { "write": true,  "read": true  },
      "GZIP":    { "write": true,  "read": true  },
      "LZ4":     { "write": false, "read": false, "_note": "Apache marks LZ4 (deprecated codec) as unsupported; parquet-java supports LZ4_RAW instead" },
      "LZ4_RAW": { "write": true,  "read": true  },
      "LZO":     { "write": false, "read": false },
      "SNAPPY":  { "write": true,  "read": true  },
      "ZSTD":    { "write": true,  "read": true  }
    },
    "encoding": {
      "PLAIN":                   { "write": true,  "read": true  },
      "PLAIN_DICTIONARY":        { "write": true,  "read": true  },
      "RLE_DICTIONARY":          { "write": true,  "read": true  },
      "RLE":                     { "write": true,  "read": true  },
      "BIT_PACKED":              { "write": true,  "read": true  },
      "DELTA_BINARY_PACKED":     { "write": true,  "read": true  },
      "DELTA_LENGTH_BYTE_ARRAY": { "write": true,  "read": true  },
      "DELTA_BYTE_ARRAY":        { "write": true,  "read": true  },
      "BYTE_STREAM_SPLIT":       { "write": true,  "read": true  }
    },
    "logical_types": {
      "STRING":           { "write": true,  "read": true  },
      "ENUM":             { "write": true,  "read": true  },
      "UUID":             { "write": true,  "read": true  },
      "DECIMAL":          { "write": true,  "read": true  },
      "FLOAT16":          { "write": true,  "read": true,  "_note": "Only supported to use its annotated physical type" },
      "DATE":             { "write": true,  "read": true  },
      "TIME_MILLIS":      { "write": true,  "read": true  },
      "TIME_MICROS":      { "write": true,  "read": true  },
      "TIME_NANOS":       { "write": true,  "read": true  },
      "TIMESTAMP_MILLIS": { "write": true,  "read": true  },
      "TIMESTAMP_MICROS": { "write": true,  "read": true  },
      "TIMESTAMP_NANOS":  { "write": true,  "read": true  },
      "INT96":            { "write": true,  "read": true,  "_note": "Apache tracks this as a physical type (physical-int96: full)" },
      "INTERVAL":         { "write": true,  "read": true,  "_note": "Only supported to use its annotated physical type" },
      "JSON":             { "write": true,  "read": true,  "_note": "Only supported to use its annotated physical type" },
      "BSON":             { "write": true,  "read": true,  "_note": "Only supported to use its annotated physical type" }
    },
    "advanced_features": {
      "BLOOM_FILTER":      { "write": true,  "read": true  },
      "STATISTICS":        { "write": true,  "read": true  },
      "PAGE_INDEX":        { "write": true,  "read": true  },
      "COLUMN_ENCRYPTION": { "write": true,  "read": true  },
      "DATA_PAGE_V2":      { "write": true,  "read": true  }
    }
  },
  "parquet-rs": {
